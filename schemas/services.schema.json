{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitee.com/zlx23/homehub/schemas/services.schema.json",
  "title": "HomeHub Service Manifest",
  "description": "Single source of truth for HomeHub services. IAM manifests, Control catalog, and Traefik routes derive from this file.",
  "type": "object",
  "required": ["version", "services"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version"
    },
    "services": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "name", "audience", "kind", "visibility", "health"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique machine-readable identifier"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "audience": {
            "type": "string",
            "pattern": "^homehub-[a-z][a-z0-9-]*$",
            "description": "Unique IAM audience (must match pattern homehub-<id>)"
          },
          "kind": {
            "type": "string",
            "enum": ["control-plane", "portal", "business-service", "infrastructure-service", "bridge"]
          },
          "route": {
            "description": "Public route prefix, or null for internal-only services",
            "oneOf": [
              {"type": "string", "pattern": "^/"},
              {"type": "null"}
            ]
          },
          "visibility": {
            "type": "string",
            "enum": ["owner", "shared", "internal"]
          },
          "health": {
            "type": "string",
            "format": "uri"
          },
          "permissions": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z]+\\.[a-z]+\\.[a-z]+$"
            }
          }
        }
      }
    }
  }
}
