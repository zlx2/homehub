{
  "version": 2,
  "source": "services.yaml",
  "services": [
    {
      "id": "drop",
      "name": "Drop",
      "description": "原图与文本临时中转服务",
      "kind": "business-service",
      "health_url": "http://drop:8080/health/ready",
      "path": "/drop",
      "visibility": "shared"
    },
    {
      "id": "iam",
      "name": "身份与权限",
      "description": "用户、会话、令牌与授权中心",
      "kind": "control-plane",
      "health_url": "http://iam:8080/health/ready",
      "path": "/api/iam",
      "visibility": "owner"
    },
    {
      "id": "control",
      "name": "系统看板",
      "description": "服务状态聚合",
      "kind": "control-plane",
      "health_url": "http://control:8080/health/ready",
      "path": "/api/control",
      "visibility": "owner"
    },
    {
      "id": "portal",
      "name": "HomeHub Portal",
      "description": "登录页与聚合首页",
      "kind": "portal",
      "health_url": "http://portal:8080/health",
      "path": "/",
      "visibility": "owner"
    }
  ]
}
