{
  "providers": [
    {
      "id": "deepseek",
      "base_url": "https://api.deepseek.com",
      "api_key_file": "/run/secrets/ai_deepseek_api_key"
    },
    {
      "id": "opencode-go",
      "base_url": "https://opencode.ai/zen/go/v1",
      "api_key_file": "/run/secrets/ai_opencode_go_api_key"
