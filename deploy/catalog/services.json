{
  "services": [
    {
      "id": "homehub-control",
      "name": "HomeHub Control",
      "description": "身份、权限、分享策略与服务目录的控制平面。",
      "icon": "C",
      "route": "/api/v1/system",
      "visibility": "owner",
      "share_enabled": false,
      "health_url": "http://control:8080/health/live"
    },
    {
      "id": "homehub-edge",
      "name": "HomeHub Edge",
      "description": "负责入口路由、流量治理与外部鉴权委托的Traefik数据平面。",
      "icon": "E",
      "route": "",
      "visibility": "internal",
      "share_enabled": false,
      "health_url": "http://traefik:8081/ping"
    },
    {
      "id": "server-monitor",
      "name": "服务器监控",
      "description": "查看主机资源、Docker 容器与历史指标的只读运维面板。",
      "icon": "S",
      "route": "/server/",
      "visibility": "owner",
      "share_enabled": false,
      "health_url": "http://beszel:8090/api/health"
    },
    {
	  "id": "drop",
	  "name": "Drop",
	  "description": "临时发送文字与文件；本人可管理，分享访客可直接使用。",
	  "icon": "↓",
	  "route": "/drop/",
	  "visibility": "shared",
	  "share_enabled": true,
	  "health_url": "http://drop:8080/health/ready"
    }
  ]
}
