{
  "services": [
    {
      "id": "homehub-control",
      "name": "HomeHub Control",
      "description": "身份、权限、分享策略与服务目录的控制平面。",
      "icon": "C",
      "route": "/api/v1/system",
      "visibility": "owner",
      "share_enabled": false,
      "health_url": "http://control:8080/health/live"
    },
    {
      "id": "homehub-edge",
      "name": "HomeHub Edge",
      "description": "负责入口路由、流量治理与外部鉴权委托的Traefik数据平面。",
      "icon": "E",
      "route": "",
      "visibility": "internal",
      "share_enabled": false,
      "health_url": "http://traefik:8081/ping"
    },
    {
      "id": "server-monitor",
      "name": "服务器监控",
      "description": "查看主机资源、Docker 容器与历史指标的只读运维面板。",
      "icon": "S",
      "route": "/server/",
      "visibility": "owner",
      "share_enabled": false,
      "health_url": "http://beszel:8090/api/health"
    },
    {
      "id": "demo-decider",
      "name": "随机决策器",
      "description": "Go 编写的无状态随机选择器，用于验证网关鉴权、路由和服务分享。",
      "icon": "D",
      "route": "/demo/decider/",
      "visibility": "shared",
      "share_enabled": true,
      "health_url": "http://demo-decider:8080/health/live"
    },
    {
      "id": "demo-counter",
      "name": "共享计数器",
      "description": "Rust 与独立 SQLite 构成的持久化服务，用于验证写操作和数据隔离。",
      "icon": "N",
      "route": "/demo/counter/",
      "visibility": "shared",
      "share_enabled": true,
      "health_url": "http://demo-counter:8080/health/live"
    }
  ]
}
